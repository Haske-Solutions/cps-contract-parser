{
  "name": "cps-contract-parser",
  "version": "1.0.11",
  "description": "CPS Contract Rate Sheet Parser — Electron desktop app",
  "author": "Cheli and Peacock Safaris",
  "repository": {
    "type": "git",
    "url": "https://github.com/Haske-Solutions/cps-contract-parser.git"
  },
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && bash scripts/package-mac-ci.sh",
    "package:win": "npm run build && electron-builder --win",
    "icons:generate": "bash scripts/generate-icons.sh",
    "installer-assets:generate": "node scripts/generate-installer-assets.js",
    "branding:generate": "npm run icons:generate && npm run installer-assets:generate",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:renderer": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "release:patch": "npm run test && npm run build && npm version patch",
    "release:minor": "npm run test && npm run build && npm version minor",
    "release:major": "npm run test && npm run build && npm version major",
    "release:publish": "git push && git push --tags",
    "dev:server": "npm run dev --prefix server",
    "start:server": "npm run start --prefix server",
    "rebuild:native": "npx @electron/rebuild --force --only keytar,@duckdb/node-api",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1071.0",
    "@aws-sdk/credential-provider-node": "^3.972.57",
    "@base-ui/react": "^1.6.0",
    "@duckdb/node-api": "^1.5.3-r.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@types/archiver": "^5.3.4",
    "archiver": "^5.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "keytar": "^7.9.0",
    "lucide-react": "^1.21.0",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-data-grid": "^7.0.0-beta.47",
    "react-dom": "^18.3.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "npm:@e965/xlsx@0.20.3",
    "zustand": "^5.0.3"
  },
  "optionalDependencies": {
    "@duckdb/node-bindings-darwin-arm64": "1.5.3-r.3",
    "@duckdb/node-bindings-darwin-x64": "1.5.3-r.3",
    "@duckdb/node-bindings-win32-arm64": "1.5.3-r.3",
    "@duckdb/node-bindings-win32-x64": "1.5.3-r.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "25.1.8",
    "electron-playwright-helpers": "^1.7.1",
    "eslint": "^9.17.0",
    "jimp": "^1.6.1",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.8"
  }
}
