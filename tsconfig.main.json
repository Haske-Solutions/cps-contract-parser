{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist/main",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/main",
    "src/preload",
    "src/shared/types.ts",
    "src/shared/constants.ts",
    "src/shared/parserInvoke.ts",
    "src/shared/tokenDisplay.ts"
  ],
  "exclude": ["src/renderer"]
}
